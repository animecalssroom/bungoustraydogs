# Copy this file to .env.local and fill values before running locally.

# Supabase (public + service role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL / deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Gemini (Google) API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Upstash Redis (REST credentials). Get from Upstash console: REST URL and REST Token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: configure quick/common-answer limiter (conservative defaults)
COMMON_ANSWER_WINDOW_SECONDS=300
COMMON_ANSWER_LIMIT=3

# Bot schedule cron overrides (optional)
# BOT_CHECK_REPLIES_CRON="*/5 * * * *"
# RESOLVE_DUEL_CRON="* * * * *"
# BOT_SUBMIT_CRON="* * * * *"

# Bot secrets
# BOT_SECRET=
# BOT_DUEL_SECRET=

# QStash (Upstash) scheduling endpoint (optional)
# QSTASH_URL=https://qstash-us-east-1.upstash.io
# QSTASH_TOKEN=

# After populating .env.local run:
# npm install
# npm run build
# node scripts/register-bot-schedules.ts
# npm run dev
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_APP_URL=http://localhost:3000
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
BOT_DUEL_SECRET=your-bot-duel-secret
OWNER_USER_ID=your-owner-user-id
